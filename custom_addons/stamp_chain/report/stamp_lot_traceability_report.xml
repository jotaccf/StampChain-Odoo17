<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="action_stamp_lot_traceability" model="ir.actions.report">
      <field name="name">Rastreabilidade do Lote INCM</field>
      <field name="model">tobacco.stamp.lot</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">stamp_chain.stamp_lot_traceability</field>
      <field name="report_file">stamp_chain.stamp_lot_traceability</field>
      <field name="binding_model_id" ref="model_tobacco_stamp_lot"/>
      <field name="binding_type">report</field>
    </record>

    <template id="stamp_lot_traceability">
      <t t-call="web.html_container">
        <t t-foreach="docs" t-as="lot">
          <t t-call="web.external_layout">
            <div class="page">
              <h2>Rastreabilidade — Lote INCM</h2>

              <table class="table table-sm table-bordered" style="width:60%">
                <tr><th>Referencia INCM</th><td><strong><t t-esc="lot.incm_ref"/></strong></td></tr>
                <tr><th>Referencia Interna</th><td><t t-esc="lot.name"/></td></tr>
                <tr><th>Zona IEC</th><td><t t-esc="lot.zone_id.name"/> (<t t-esc="lot.zone_id.code"/>)</td></tr>
                <tr><th>Data Recepcao</th><td><t t-esc="lot.reception_date"/></td></tr>
                <tr><th>Quantidade Recebida</th><td><t t-esc="lot.qty_received"/></td></tr>
                <tr><th>Sequencia FIFO</th><td><t t-esc="lot.fifo_sequence"/></td></tr>
                <tr><th>eDIC (AT)</th><td><t t-esc="lot.edic_ref or 'Pendente'"/></td></tr>
                <tr><th>e-DA (AT)</th><td><t t-esc="lot.eda_ref or 'N/A'"/></td></tr>
                <tr><th>Armazem</th><td><t t-esc="lot.warehouse_id.name or 'N/D'"/></td></tr>
                <tr><th>Estado</th><td><t t-esc="dict(lot._fields['state'].selection).get(lot.state)"/></td></tr>
              </table>

              <div class="row mb-4 mt-3">
                <div class="col-3 text-center"><strong>Disponiveis</strong><br/><span style="font-size:1.5em"><t t-esc="lot.qty_available"/></span></div>
                <div class="col-3 text-center"><strong>Utilizados</strong><br/><span style="font-size:1.5em"><t t-esc="lot.qty_used"/></span></div>
                <div class="col-3 text-center"><strong>Quebras</strong><br/><span style="font-size:1.5em"><t t-esc="lot.qty_broken"/></span></div>
                <div class="col-3 text-center"><strong>Quarentena</strong><br/><span style="font-size:1.5em"><t t-esc="len(lot.serial_ids.filtered(lambda s: s.state == 'quarantine'))"/></span></div>
              </div>

              <h4>Numeros de Serie</h4>
              <table class="table table-sm table-striped" style="font-size:0.85em">
                <thead>
                  <tr>
                    <th>Numero de Serie</th>
                    <th>Estado</th>
                    <th>Ordem Producao</th>
                    <th>Encomenda</th>
                    <th>Expedicao</th>
                    <th>Data Utilizacao</th>
                    <th>eDIC</th>
                  </tr>
                </thead>
                <tbody>
                  <t t-foreach="lot.serial_ids" t-as="serial">
                    <tr>
                      <td><t t-esc="serial.serial_number"/></td>
                      <td><t t-esc="dict(serial._fields['state'].selection).get(serial.state)"/></td>
                      <td><t t-esc="serial.production_id.name or ''"/></td>
                      <td><t t-esc="serial.sale_order_id.name or ''"/></td>
                      <td><t t-esc="serial.picking_id.name or ''"/></td>
                      <td><t t-esc="serial.used_date or ''"/></td>
                      <td><t t-esc="serial.edic_ref or ''"/></td>
                    </tr>
                  </t>
                </tbody>
              </table>

              <t t-if="lot.fiscal_document_ids">
                <h4 class="mt-3">Documentos Fiscais</h4>
                <table class="table table-sm">
                  <thead>
                    <tr><th>Referencia</th><th>Tipo</th><th>Data</th><th>Codigo AT</th><th>Estado</th></tr>
                  </thead>
                  <tbody>
                    <t t-foreach="lot.fiscal_document_ids" t-as="fdoc">
                      <tr>
                        <td><t t-esc="fdoc.name"/></td>
                        <td><t t-esc="fdoc.document_type"/></td>
                        <td><t t-esc="fdoc.date"/></td>
                        <td><t t-esc="fdoc.at_code or 'Pendente'"/></td>
                        <td><t t-esc="dict(fdoc._fields['state'].selection).get(fdoc.state)"/></td>
                      </tr>
                    </t>
                  </tbody>
                </table>
              </t>

              <p class="text-muted small mt-4">StampChain — Rastreabilidade INCM. Uso interno.</p>
            </div>
          </t>
        </t>
      </t>
    </template>
  </data>
</odoo>
