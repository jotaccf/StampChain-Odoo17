<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="action_report_stamp_zone" model="ir.actions.report">
    <field name="name">Conta Corrente por Zona</field>
    <field name="model">tobacco.stamp.zone</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">stamp_chain.report_stamp_zone</field>
    <field name="report_file">stamp_chain.report_stamp_zone</field>
    <field name="binding_model_id" ref="model_tobacco_stamp_zone"/>
    <field name="binding_type">report</field>
  </record>

  <template id="report_stamp_zone">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="zone">
        <t t-call="web.external_layout">
          <div class="page">
            <h2>Conta Corrente de Estampilhas</h2>
            <h3><t t-esc="zone.name"/> (<t t-esc="zone.code"/>)</h3>
            <div class="row mt-3">
              <div class="col-4">
                <strong>Saldo Actual:</strong>
                <span t-esc="zone.balance"/>
              </div>
              <div class="col-4">
                <strong>Total Recebido:</strong>
                <span t-esc="zone.total_received"/>
              </div>
              <div class="col-4">
                <strong>Total Utilizado:</strong>
                <span t-esc="zone.total_used"/>
              </div>
            </div>
            <table class="table table-sm mt-4">
              <thead>
                <tr>
                  <th>Data</th>
                  <th>Tipo</th>
                  <th>Quantidade</th>
                  <th>Saldo</th>
                  <th>Referencia</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="zone.movement_ids" t-as="mov">
                  <tr>
                    <td><t t-esc="mov.date" t-options="{'widget': 'datetime'}"/></td>
                    <td><t t-esc="mov.move_type"/></td>
                    <td><t t-esc="mov.qty"/></td>
                    <td><t t-esc="mov.balance_after"/></td>
                    <td><t t-esc="mov.reference"/></td>
                  </tr>
                </t>
              </tbody>
            </table>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
