<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_picking_form_handheld" model="ir.ui.view">
      <field name="name">stock.picking.form.stampchain.handheld</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form"/>
      <field name="arch" type="xml">
        <!-- Botao Handheld -->
        <xpath expr="//button[@name='button_validate']" position="before">
          <button name="action_open_handheld"
                  string="Modo Handheld"
                  type="object"
                  class="btn-primary sc-btn-handheld"
                  icon="fa-mobile"
                  invisible="state in ('done', 'cancel')"
                  help="Abrir picking guiado para handheld Android"/>
        </xpath>
        <!-- Banner erro Wisedat + botao retry -->
        <xpath expr="//sheet" position="before">
          <div class="alert alert-danger"
               role="alert"
               invisible="wisedat_order_status != 'failed'"
               style="margin-bottom: 0;">
            <div class="d-flex align-items-center">
              <div class="flex-grow-1">
                <strong>Encomenda nao enviada para o Wisedat</strong>
                <br/>
                <span>Verifique a ligacao e clique em Reenviar.
                  Tentativas: <field name="wisedat_retry_count"
                                     readonly="1"
                                     class="d-inline"/>
                </span>
              </div>
              <button name="action_retry_wisedat_order"
                      string="Reenviar Wisedat"
                      type="object"
                      class="btn btn-primary ms-3"
                      icon="fa-refresh"/>
            </div>
          </div>
          <field name="wisedat_order_status" invisible="1"/>
          <field name="wisedat_error_message" invisible="1"/>
        </xpath>
        <!-- Campos Wisedat no formulario -->
        <xpath expr="//field[@name='origin']" position="after">
          <field name="wisedat_doc_id"
                 readonly="1"
                 invisible="not wisedat_doc_id"/>
          <field name="wisedat_order_status"
                 widget="badge"
                 decoration-success="wisedat_order_status == 'sent'"
                 decoration-danger="wisedat_order_status == 'failed'"
                 decoration-warning="wisedat_order_status == 'pending'"
                 readonly="1"
                 invisible="not wisedat_order_status"/>
        </xpath>
      </field>
    </record>

    <!-- Filtro Wisedat pendente na lista -->
    <record id="view_picking_search_wisedat" model="ir.ui.view">
      <field name="name">stock.picking.search.stampchain.wisedat</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_internal_search"/>
      <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
          <filter name="wisedat_failed"
                  string="Wisedat Pendente"
                  domain="[('wisedat_order_status', '=', 'failed')]"
                  icon="fa-exclamation-triangle"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
