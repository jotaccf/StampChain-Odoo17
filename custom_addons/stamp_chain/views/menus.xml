<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Root Menu -->
  <menuitem id="menu_stampchain_root"
            name="StampChain"
            web_icon="stamp_chain,static/src/img/icon.png"
            sequence="100"/>

  <!-- Dashboard -->
  <menuitem id="menu_stampchain_dashboard"
            name="Dashboard"
            parent="menu_stampchain_root"
            action="action_stamp_dashboard"
            sequence="1"/>

  <!-- Conta Corrente -->
  <menuitem id="menu_conta_corrente"
            name="Conta Corrente"
            parent="menu_stampchain_root"
            sequence="10"/>
  <menuitem id="menu_zonas"
            name="Saldos por Zona"
            parent="menu_conta_corrente"
            action="action_stamp_zone"
            sequence="1"/>
  <menuitem id="menu_movimentos"
            name="Movimentos"
            parent="menu_conta_corrente"
            action="action_stamp_movement"
            sequence="2"/>

  <!-- Estampilhas -->
  <menuitem id="menu_estampilhas"
            name="Estampilhas"
            parent="menu_stampchain_root"
            sequence="20"/>
  <menuitem id="menu_lotes"
            name="Lotes INCM"
            parent="menu_estampilhas"
            action="action_stamp_lot"
            sequence="1"/>
  <menuitem id="menu_series"
            name="Series"
            parent="menu_estampilhas"
            action="action_stamp_serial"
            sequence="2"/>
  <menuitem id="menu_quebras"
            name="Quebras"
            parent="menu_estampilhas"
            action="action_stamp_breakdown"
            sequence="3"/>
  <menuitem id="menu_recuperacoes"
            name="Recuperacoes"
            parent="menu_estampilhas"
            action="action_stamp_recovery"
            sequence="4"/>

  <!-- Operacoes -->
  <menuitem id="menu_operacoes"
            name="Operacoes"
            parent="menu_stampchain_root"
            sequence="30"/>
  <menuitem id="menu_receber_lote_ocr"
            name="Receber Lote INCM (OCR)"
            parent="menu_operacoes"
            action="action_incm_ocr_reception_wizard"
            sequence="1"/>
  <menuitem id="menu_production_start"
            name="Iniciar Estampilhagem"
            parent="menu_operacoes"
            action="action_production_start_wizard"
            sequence="2"/>
  <menuitem id="menu_production_end"
            name="Registar Fim de Producao"
            parent="menu_operacoes"
            action="action_production_end_wizard"
            sequence="3"/>
  <menuitem id="menu_picking_handheld"
            name="Picking Handheld"
            parent="menu_operacoes"
            action="stock.action_picking_tree_all"
            sequence="4"/>
  <menuitem id="menu_layout_armazem"
            name="Configurar Layout Armazem"
            parent="menu_operacoes"
            action="action_warehouse_layout_wizard"
            sequence="5"
            groups="stamp_chain.group_stamp_manager"/>
  <menuitem id="menu_location_qr"
            name="Gerar Etiquetas QR"
            parent="menu_operacoes"
            action="stock.action_location_form"
            sequence="6"/>

  <!-- Documentos Fiscais -->
  <menuitem id="menu_fiscal_docs"
            name="Documentos Fiscais"
            parent="menu_stampchain_root"
            sequence="40"/>
  <menuitem id="menu_edic"
            name="eDIC — Introducao no Consumo"
            parent="menu_fiscal_docs"
            action="action_fiscal_document_edic"
            sequence="1"/>
  <menuitem id="menu_eda"
            name="e-DA — Movimento entre Entrepostos"
            parent="menu_fiscal_docs"
            action="action_fiscal_document_eda"
            sequence="2"/>
  <menuitem id="menu_fiscal_all"
            name="Todos os Documentos"
            parent="menu_fiscal_docs"
            action="action_fiscal_document_all"
            sequence="3"/>
  <menuitem id="menu_wisedat_invoices"
            name="Facturas Wisedat"
            parent="menu_fiscal_docs"
            action="action_wisedat_invoice"
            sequence="4"/>

  <!-- Auditoria -->
  <menuitem id="menu_auditoria"
            name="Auditoria"
            parent="menu_stampchain_root"
            sequence="50"/>
  <menuitem id="menu_discrepancias"
            name="Discrepancias"
            parent="menu_auditoria"
            action="action_stamp_audit"
            sequence="1"/>
  <menuitem id="menu_encontradas"
            name="Estampilhas Encontradas"
            parent="menu_auditoria"
            action="action_stamp_found"
            sequence="2"/>
  <menuitem id="menu_contagens"
            name="Contagens Fisicas"
            parent="menu_auditoria"
            action="action_physical_count_list"
            sequence="3"/>

  <!-- Configuracoes (apenas managers) -->
  <menuitem id="menu_config"
            name="Configuracoes"
            parent="menu_stampchain_root"
            groups="stamp_chain.group_stamp_manager"
            sequence="90"/>
  <menuitem id="menu_stock_seguranca"
            name="Stock de Seguranca por Zona"
            parent="menu_config"
            action="action_stamp_zone"
            sequence="1"/>
  <menuitem id="menu_wisedat"
            name="Wisedat"
            parent="menu_config"
            action="action_wisedat_config"
            sequence="2"/>
  <menuitem id="menu_warehouses"
            name="Armazens EF/A1"
            parent="menu_config"
            action="action_warehouse_config"
            sequence="3"/>
  <menuitem id="menu_warehouse_setup"
            name="Setup Inicial Armazens"
            parent="menu_config"
            action="action_warehouse_setup_wizard"
            sequence="4"/>
  <menuitem id="menu_receber_lote_legacy"
            name="Recepcao Manual (legacy)"
            parent="menu_config"
            action="action_incm_reception_wizard"
            sequence="10"/>
</odoo>
