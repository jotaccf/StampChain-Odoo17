<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_stamp_breakdown_tree" model="ir.ui.view">
    <field name="name">tobacco.stamp.breakdown.tree</field>
    <field name="model">tobacco.stamp.breakdown</field>
    <field name="arch" type="xml">
      <tree decoration-danger="1">
        <field name="name"/>
        <field name="date"/>
        <field name="zone_id"/>
        <field name="production_id"/>
        <field name="breakdown_reason"/>
        <field name="qty_broken" class="fw-bold"/>
        <field name="user_id"/>
      </tree>
    </field>
  </record>

  <record id="view_stamp_breakdown_form" model="ir.ui.view">
    <field name="name">tobacco.stamp.breakdown.form</field>
    <field name="model">tobacco.stamp.breakdown</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <div class="oe_title">
            <h1><field name="name"/></h1>
          </div>
          <div class="sc-metric-card sc-metric-err" style="margin:12px 0; max-width:200px">
            <div class="sc-metric-label">Quebras</div>
            <div class="sc-metric-value">
              <field name="qty_broken" readonly="1" widget="integer" nolabel="1"/>
            </div>
          </div>
          <group>
            <group>
              <field name="production_id"/>
              <field name="zone_id"/>
              <field name="breakdown_reason"/>
            </group>
            <group>
              <field name="date"/>
              <field name="user_id"/>
              <field name="movement_id"/>
            </group>
          </group>
          <group>
            <field name="description"/>
            <field name="photo" filename="photo_filename"/>
            <field name="photo_filename" invisible="1"/>
          </group>
          <notebook>
            <page string="Estampilhas Quebradas" name="serials">
              <field name="serial_ids">
                <tree>
                  <field name="serial_number"/>
                  <field name="lot_id"/>
                  <field name="state" widget="badge"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <record id="action_stamp_breakdown" model="ir.actions.act_window">
    <field name="name">Quebras de Estampilhas</field>
    <field name="res_model">tobacco.stamp.breakdown</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
