<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_warehouse_config_tree" model="ir.ui.view">
    <field name="name">tobacco.warehouse.config.tree</field>
    <field name="model">tobacco.warehouse.config</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="warehouse_id"/>
        <field name="wisedat_warehouse_code" class="font-monospace fw-bold"/>
        <field name="warehouse_type" widget="badge"
               decoration-warning="warehouse_type == 'fiscal_warehouse'"
               decoration-success="warehouse_type == 'main_warehouse'"/>
        <field name="requires_edic"/>
        <field name="destination_warehouse_id"/>
        <field name="location_count" string="Localizacoes"/>
      </tree>
    </field>
  </record>

  <record id="view_warehouse_config_form" model="ir.ui.view">
    <field name="name">tobacco.warehouse.config.form</field>
    <field name="model">tobacco.warehouse.config</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_open_layout_wizard"
                  string="Configurar Layout"
                  type="object"
                  class="btn-primary sc-btn-handheld"
                  icon="fa-th"/>
        </header>
        <sheet>
          <group>
            <group string="Mapeamento">
              <field name="name"/>
              <field name="warehouse_id"/>
              <field name="wisedat_warehouse_code" class="font-monospace"/>
              <field name="warehouse_type" widget="badge"/>
            </group>
            <group string="Configuracao">
              <field name="is_fiscal_warehouse" readonly="1"/>
              <field name="requires_edic"/>
              <field name="destination_warehouse_id"/>
              <field name="wisedat_config_id"/>
              <field name="active"/>
            </group>
          </group>
          <group string="Layout Fisico" col="4">
            <field name="num_corridors" readonly="1"/>
            <field name="num_shelves" readonly="1"/>
            <field name="num_levels" readonly="1"/>
            <field name="num_positions" readonly="1"/>
            <field name="location_count" readonly="1"/>
            <field name="last_layout_date" readonly="1"/>
            <field name="last_layout_user" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_warehouse_config" model="ir.actions.act_window">
    <field name="name">Armazens EF/A1</field>
    <field name="res_model">tobacco.warehouse.config</field>
    <field name="view_mode">tree,form</field>
  </record>

  <record id="action_warehouse_setup_wizard" model="ir.actions.act_window">
    <field name="name">Setup Inicial Armazens</field>
    <field name="res_model">tobacco.warehouse.setup.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
