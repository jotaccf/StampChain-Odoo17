<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_stamp_audit_list" model="ir.ui.view">
      <field name="name">tobacco.stamp.audit.list</field>
      <field name="model">tobacco.stamp.audit</field>
      <field name="arch" type="xml">
        <tree decoration-danger="discrepancy &gt; 0"
              decoration-info="discrepancy &lt; 0"
              decoration-success="state == 'justified'">
          <field name="name"/>
          <field name="date"/>
          <field name="zone_id"/>
          <field name="discrepancy_direction"/>
          <field name="discrepancy"/>
          <field name="net_discrepancy"/>
          <field name="audit_type"/>
          <field name="state"/>
          <field name="is_justified"/>
        </tree>
      </field>
    </record>

    <record id="view_stamp_audit_form" model="ir.ui.view">
      <field name="name">tobacco.stamp.audit.form</field>
      <field name="model">tobacco.stamp.audit</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_justify"
                    string="Justificar"
                    type="object"
                    class="btn-primary"
                    invisible="state != 'open'"/>
            <button name="action_add_found_stamp"
                    string="Registar Estampilha Encontrada"
                    type="object"
                    class="btn-secondary"
                    invisible="state != 'open'"/>
            <field name="state" widget="statusbar"/>
          </header>
          <sheet>
            <!-- Metric cards (C1) -->
            <div class="row mt-2 mb-3">
              <div class="col-4">
                <div class="sc-metric-card">
                  <div class="sc-metric-label">Teorico</div>
                  <div class="sc-metric-value">
                    <field name="stock_theoretical" readonly="1" widget="integer" nolabel="1"/>
                  </div>
                </div>
              </div>
              <div class="col-4">
                <div class="sc-metric-card">
                  <div class="sc-metric-label">Real</div>
                  <div class="sc-metric-value">
                    <field name="stock_real" readonly="1" widget="integer" nolabel="1"/>
                  </div>
                </div>
              </div>
              <div class="col-4">
                <div class="sc-metric-card sc-metric-err" invisible="discrepancy &lt;= 0">
                  <div class="sc-metric-label">Discrepancia</div>
                  <div class="sc-metric-value">
                    <field name="discrepancy" readonly="1" widget="integer" nolabel="1"/>
                  </div>
                </div>
                <div class="sc-metric-card sc-metric-info" invisible="discrepancy &gt;= 0">
                  <div class="sc-metric-label">Discrepancia</div>
                  <div class="sc-metric-value">
                    <field name="discrepancy" readonly="1" widget="integer" nolabel="1"/>
                  </div>
                </div>
                <div class="sc-metric-card sc-metric-ok" invisible="discrepancy != 0">
                  <div class="sc-metric-label">Discrepancia</div>
                  <div class="sc-metric-value">
                    <field name="discrepancy" readonly="1" widget="integer" nolabel="1"/>
                  </div>
                </div>
              </div>
            </div>
            <group>
              <group string="Dados">
                <field name="zone_id" readonly="1"/>
                <field name="date" readonly="1"/>
                <field name="audit_type" readonly="1"/>
                <field name="production_id" readonly="1" invisible="not production_id"/>
                <field name="discrepancy_direction" readonly="1"/>
              </group>
              <group string="Stock">
                <field name="stock_real_auto" readonly="1"/>
                <field name="stock_real_manual" readonly="1" invisible="stock_real_manual == 0"/>
              </group>
            </group>
            <notebook>
              <page string="Justificacao">
                <div invisible="state != 'open'" class="mb-3">
                  <field name="justification" placeholder="Introduza a justificacao..."/>
                  <div class="sc-hh-feedback warn" style="margin-top:8px">
                    <div class="sc-hh-feedback-sub">
                      A justificacao e permanente e nao pode ser alterada.
                    </div>
                  </div>
                </div>
                <div invisible="state == 'open'">
                  <group>
                    <field name="justification" readonly="1"/>
                    <field name="justified_by" readonly="1"/>
                    <field name="justified_date" readonly="1"/>
                  </group>
                </div>
              </page>
              <page string="Estampilhas Encontradas">
                <field name="found_ids">
                  <tree decoration-success="state == 'approved'"
                        decoration-danger="state == 'rejected'"
                        decoration-warning="state == 'pending'">
                    <field name="name"/>
                    <field name="serial_code" class="font-monospace"/>
                    <field name="found_location"/>
                    <field name="found_by"/>
                    <field name="date"/>
                    <field name="state"/>
                  </tree>
                </field>
                <group>
                  <field name="qty_found" readonly="1"/>
                  <field name="net_discrepancy" readonly="1"/>
                </group>
              </page>
            </notebook>
          </sheet>
          <chatter/>
        </form>
      </field>
    </record>

    <record id="view_stamp_audit_search" model="ir.ui.view">
      <field name="name">tobacco.stamp.audit.search</field>
      <field name="model">tobacco.stamp.audit</field>
      <field name="arch" type="xml">
        <search>
          <field name="zone_id"/>
          <field name="audit_type"/>
          <filter name="open" string="Abertos" domain="[('state', '=', 'open')]"/>
          <filter name="justified" string="Justificados" domain="[('state', '=', 'justified')]"/>
          <group expand="0" string="Agrupar">
            <filter name="group_zone" string="Zona" context="{'group_by': 'zone_id'}"/>
            <filter name="group_direction" string="Sentido" context="{'group_by': 'discrepancy_direction'}"/>
          </group>
        </search>
      </field>
    </record>

    <record id="action_stamp_audit" model="ir.actions.act_window">
      <field name="name">Discrepancias</field>
      <field name="res_model">tobacco.stamp.audit</field>
      <field name="view_mode">tree,form</field>
    </record>

  </data>
</odoo>
