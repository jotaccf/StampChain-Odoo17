<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_stamp_lot_tree" model="ir.ui.view">
    <field name="name">tobacco.stamp.lot.tree</field>
    <field name="model">tobacco.stamp.lot</field>
    <field name="arch" type="xml">
      <tree decoration-success="lot_status == 'reception'"
            decoration-info="lot_status == 'in_machine'"
            decoration-warning="lot_status == 'partial'"
            decoration-danger="lot_status == 'exhausted'">
        <field name="incm_ref"/>
        <field name="zone_id"/>
        <field name="serial_prefix" class="font-monospace"/>
        <field name="lot_status" widget="badge"
               decoration-success="lot_status == 'reception'"
               decoration-info="lot_status == 'in_machine'"
               decoration-warning="lot_status == 'partial'"
               decoration-danger="lot_status == 'exhausted'"/>
        <field name="qty_received"/>
        <field name="qty_available" class="fw-bold text-success"/>
        <field name="qty_consumed"/>
        <field name="reception_date"/>
        <field name="fifo_sequence"/>
      </tree>
    </field>
  </record>

  <record id="view_stamp_lot_form" model="ir.ui.view">
    <field name="name">tobacco.stamp.lot.form</field>
    <field name="model">tobacco.stamp.lot</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,received,in_use,exhausted"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1><field name="name"/></h1>
          </div>
          <!-- Range de seriais -->
          <div class="sc-hh-code-box" style="margin:12px 0">
            <div class="sc-hh-code-text">
              <field name="serial_prefix" readonly="1" nolabel="1" class="font-monospace"/>
            </div>
            <div class="sc-hh-code-sub">
              Sufixo: <field name="serial_suffix_start" readonly="1" nolabel="1" style="display:inline"/>
              – <field name="serial_suffix_end" readonly="1" nolabel="1" style="display:inline"/>
              | Disponivel ate: <field name="current_suffix_end" readonly="1" nolabel="1" style="display:inline"/>
            </div>
          </div>
          <!-- Metric cards -->
          <div class="row mb-3">
            <div class="col-3">
              <div class="sc-metric-card">
                <div class="sc-metric-label">Recebidas</div>
                <div class="sc-metric-value">
                  <field name="qty_received" readonly="1" widget="integer" nolabel="1"/>
                </div>
              </div>
            </div>
            <div class="col-3">
              <div class="sc-metric-card sc-metric-ok">
                <div class="sc-metric-label">Disponiveis</div>
                <div class="sc-metric-value">
                  <field name="qty_available" readonly="1" widget="integer" nolabel="1"/>
                </div>
              </div>
            </div>
            <div class="col-3">
              <div class="sc-metric-card">
                <div class="sc-metric-label">Consumidas</div>
                <div class="sc-metric-value">
                  <field name="qty_consumed" readonly="1" widget="integer" nolabel="1"/>
                </div>
              </div>
            </div>
            <div class="col-3">
              <div class="sc-metric-card sc-metric-err">
                <div class="sc-metric-label">Quebras</div>
                <div class="sc-metric-value">
                  <field name="qty_broken" readonly="1" widget="integer" nolabel="1"/>
                </div>
              </div>
            </div>
          </div>
          <group>
            <group>
              <field name="incm_ref"/>
              <field name="zone_id"/>
              <field name="reception_date"/>
              <field name="fifo_sequence"/>
              <field name="lot_status" widget="badge"/>
            </group>
            <group>
              <field name="first_serial_code" readonly="1" class="font-monospace"/>
              <field name="edic_ref" readonly="1"/>
              <field name="eda_ref" readonly="1"/>
              <field name="warehouse_id"/>
            </group>
          </group>
          <notebook>
            <page string="Numeros de Serie" name="serials">
              <field name="serial_ids">
                <tree>
                  <field name="serial_number"/>
                  <field name="state" widget="badge"/>
                  <field name="production_id"/>
                  <field name="used_date"/>
                </tree>
              </field>
            </page>
            <page string="Notas" name="notes">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <record id="view_stamp_lot_search" model="ir.ui.view">
    <field name="name">tobacco.stamp.lot.search</field>
    <field name="model">tobacco.stamp.lot</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="incm_ref"/>
        <field name="zone_id"/>
        <filter name="received" string="Recebidos"
                domain="[('state', '=', 'received')]"/>
        <filter name="in_use" string="Em Uso"
                domain="[('state', '=', 'in_use')]"/>
        <group expand="0" string="Agrupar por">
          <filter name="group_zone" string="Zona"
                  context="{'group_by': 'zone_id'}"/>
          <filter name="group_state" string="Estado"
                  context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_stamp_lot" model="ir.actions.act_window">
    <field name="name">Lotes INCM</field>
    <field name="res_model">tobacco.stamp.lot</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
