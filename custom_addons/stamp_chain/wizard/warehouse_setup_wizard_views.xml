<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_warehouse_setup_wizard_form" model="ir.ui.view">
    <field name="name">tobacco.warehouse.setup.wizard.form</field>
    <field name="model">tobacco.warehouse.setup.wizard</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="wisedat_config_id"/>
          <field name="ef_warehouse_id"/>
          <field name="create_ef"/>
          <field name="a1_warehouse_id"/>
          <field name="create_a1"/>
        </group>
        <footer>
          <button name="action_setup"
                  string="Configurar Armazens EF e A1"
                  type="object" class="btn-primary"/>
          <button string="Cancelar"
                  class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
