<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_production_start_wizard_form" model="ir.ui.view">
    <field name="name">tobacco.production.start.wizard.form</field>
    <field name="model">tobacco.production.start.wizard</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="production_id" readonly="1"/>
          <field name="zone_id"/>
        </group>
        <notebook>
          <page string="Lote 1">
            <group>
              <field name="lot1_id"/>
              <field name="lot1_range" readonly="1"/>
              <field name="lot1_scan" placeholder="Ex: ZZAYC000"/>
              <field name="lot1_scan_warning" readonly="1"/>
              <field name="lot1_scan_confirmed"/>
            </group>
          </page>
          <page string="Lote 2">
            <group>
              <field name="lot2_id"/>
              <field name="lot2_range" readonly="1"/>
              <field name="lot2_scan" placeholder="Ex: ZZAYF000"/>
              <field name="lot2_scan_warning" readonly="1"/>
              <field name="lot2_scan_confirmed"/>
            </group>
          </page>
        </notebook>
        <div class="alert alert-info">
          Picar a estampilha do topo de cada maco ao colocar na maquina.
        </div>
        <footer>
          <button name="action_confirm" string="Iniciar Producao"
                  type="object" class="btn-primary"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
  <record id="action_production_start_wizard" model="ir.actions.act_window">
    <field name="name">Iniciar Estampilhagem</field>
    <field name="res_model">tobacco.production.start.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
