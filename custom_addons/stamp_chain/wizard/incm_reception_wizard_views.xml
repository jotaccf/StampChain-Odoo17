<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_incm_reception_wizard_form" model="ir.ui.view">
    <field name="name">tobacco.incm.reception.wizard.form</field>
    <field name="model">tobacco.incm.reception.wizard</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <group>
            <field name="incm_ref"/>
            <field name="zone_id"/>
            <field name="reception_date"/>
          </group>
          <group>
            <field name="qty_lots"/>
            <field name="qty_total"/>
          </group>
        </group>
        <group>
          <field name="notes"/>
        </group>
        <footer>
          <button name="action_confirm"
                  string="Confirmar Recepcao"
                  type="object"
                  class="btn-primary"/>
          <button string="Cancelar"
                  class="btn-secondary"
                  special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_incm_reception_wizard" model="ir.actions.act_window">
    <field name="name">Receber Lote INCM</field>
    <field name="res_model">tobacco.incm.reception.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
