<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_incm_reception_wizard_form" model="ir.ui.view">
    <field name="name">tobacco.incm.reception.wizard.form</field>
    <field name="model">tobacco.incm.reception.wizard</field>
    <field name="arch" type="xml">
      <form>
        <div class="sc-hh-topbar green">
          <div>
            <div class="sc-hh-topbar-title">Receber Lote INCM</div>
            <div class="sc-hh-topbar-sub">Wizard antigo (formato longo)</div>
          </div>
        </div>
        <div class="sc-hh-body">
          <group>
            <group>
              <field name="incm_ref"/>
              <field name="zone_id"/>
              <field name="reception_date"/>
            </group>
            <group>
              <field name="qty_lots"/>
              <field name="qty_total" readonly="1"/>
            </group>
          </group>
          <group>
            <field name="notes" placeholder="Observacoes..."/>
          </group>
        </div>
        <footer>
          <button name="action_confirm"
                  string="Confirmar Recepcao"
                  type="object"
                  class="btn-primary sc-hh-btn primary"
                  style="min-width:200px"/>
          <button string="Cancelar"
                  class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_incm_reception_wizard" model="ir.actions.act_window">
    <field name="name">Receber Lote INCM</field>
    <field name="res_model">tobacco.incm.reception.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
