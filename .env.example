# StampChain — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# PostgreSQL
POSTGRES_DB=stampchain_dev
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Odoo connection
HOST=db
PORT=5432
USER=odoo
PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Wisedat API (optional)
# WISEDAT_API_URL=http://your-wisedat-server/api
# WISEDAT_API_KEY=your-api-key-here
